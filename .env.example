# ── Core ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
JWT_SECRET=change-this-to-a-random-32-plus-char-string
PORT=3000

# ── URLs (update after deploying) ──
APP_URL=https://criminal.lexself.ca
FAMILY_APP_URL=https://family.lexself.ca
# Or if running both on one domain:
# APP_URL=https://lexself.ca

# ── Stripe ──
# Get from https://dashboard.stripe.com → Products → Pricing
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Stripe Price IDs ──
# Create each as a recurring monthly price in Stripe Dashboard:

# Criminal only plans
STRIPE_PRICE_CRIMINAL_ESSENTIAL=price_xxx   # $24.99/month CAD
STRIPE_PRICE_CRIMINAL_COMPLETE=price_xxx    # $44.99/month CAD

# Family only plans
STRIPE_PRICE_FAMILY_ESSENTIAL=price_xxx     # $24.99/month CAD
STRIPE_PRICE_FAMILY_COMPLETE=price_xxx      # $44.99/month CAD

# Both products plans (discounted bundle)
STRIPE_PRICE_BOTH_ESSENTIAL=price_xxx       # $39.99/month CAD
STRIPE_PRICE_BOTH_COMPLETE=price_xxx        # $59.99/month CAD

# ── Admin ──
ADMIN_PASSWORD=choose-a-strong-admin-password

# ── Database ──
# DB_PATH=/app/data/lexself.db

# ─────────────────────────────────────────
# HOW TO SET UP STRIPE PRICES:
# 1. Go to dashboard.stripe.com → Products → Add product
# 2. Create "LexSelf Criminal Essential" → $24.99/month CAD recurring
# 3. Copy the Price ID (starts with price_) into STRIPE_PRICE_CRIMINAL_ESSENTIAL
# 4. Repeat for each plan above
# 5. For one-time purchases (case analysis), no price ID needed —
#    billing.js generates them dynamically at $49 CAD
# 6. Set up webhook in Stripe Dashboard → Developers → Webhooks
#    URL: https://yourapp.com/api/billing/webhook
#    Events: checkout.session.completed, customer.subscription.created,
#            customer.subscription.updated, customer.subscription.deleted
# 7. Copy the webhook signing secret to STRIPE_WEBHOOK_SECRET
# ─────────────────────────────────────────
